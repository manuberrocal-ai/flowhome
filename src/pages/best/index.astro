---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lists = (await getCollection('best-of')).sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout title="Best Smart Home Picks | FlowHome" description="Browse FlowHome best-of smart home buying guides for starter kits, robot vacuums, security basics, and more." canonicalURL="https://flowhome.dev/best/">
  <section class="premium-page-hero">
    <p class="text-sm font-bold uppercase tracking-wide text-blue-700">Buying guides</p>
    <h1 class="mt-2 text-4xl font-black text-slate-950">Best smart home picks</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-600">Curated shortlists for common smart home goals, from starter kits to cleaning automation and basic security.</p>
  </section>
  <section class="mt-8 grid gap-6 md:grid-cols-3">
    {lists.map((list) => <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-bold uppercase tracking-wide text-blue-700">{list.data.category.replaceAll('-', ' ')}</p>
      <h2 class="mt-2 text-2xl font-extrabold text-slate-950"><a href={'/best/' + list.data.slug + '/'} class="hover:text-blue-700">{list.data.title}</a></h2>
      <p class="mt-3 text-slate-600">{list.data.description}</p>
      <a href={'/best/' + list.data.slug + '/'} class="mt-5 inline-flex font-bold text-blue-700 hover:underline">Open guide →</a>
    </article>)}
  </section>
</BaseLayout>
