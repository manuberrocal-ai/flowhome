---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Smart Home Savings Calculator | FlowHome" description="Estimate monthly savings from smart plugs, lighting, thermostats, and automation routines." canonicalURL="https://flowhome.dev/calculator/">
  <section class="premium-page-hero">
    <p class="text-sm font-bold uppercase tracking-wide text-blue-700">Savings tool</p>
    <h1 class="mt-2 text-4xl font-black text-slate-950 md:text-5xl">Smart home savings calculator</h1>
    <p class="mt-3 max-w-2xl text-lg leading-8 text-slate-600">Estimate whether an energy-saving smart plug, bulb, thermostat routine, or automation can pay for itself. Use this as a planning guide, then confirm real rates and device specs before buying.</p>
    <form id="savings-form" class="mt-8 grid gap-4 md:grid-cols-4">
      <label class="font-bold text-slate-800">Device watts<span class="mt-1 block text-xs font-semibold text-slate-500">Power draw while running</span><input id="watts" name="watts" type="number" value="60" min="0" step="1" inputmode="decimal" class="mt-2 min-h-12 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100" /></label>
      <label class="font-bold text-slate-800">Hours/day saved<span class="mt-1 block text-xs font-semibold text-slate-500">Avoided runtime</span><input id="hours" name="hours" type="number" value="3" min="0" max="24" step="0.25" inputmode="decimal" class="mt-2 min-h-12 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100" /></label>
      <label class="font-bold text-slate-800">Electricity $/kWh<span class="mt-1 block text-xs font-semibold text-slate-500">Local utility rate</span><input id="rate" name="rate" type="number" value="0.17" min="0" step="0.01" inputmode="decimal" class="mt-2 min-h-12 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100" /></label>
      <label class="font-bold text-slate-800">Device cost<span class="mt-1 block text-xs font-semibold text-slate-500">Final price paid</span><input id="cost" name="cost" type="number" value="25" min="0" step="0.01" inputmode="decimal" class="mt-2 min-h-12 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100" /></label>
      <div class="md:col-span-4">
        <button id="calc" type="submit" class="premium-action flow-wave mt-2 min-h-12 rounded-2xl px-6 py-3 font-black text-white">Calculate savings</button>
      </div>
    </form>
    <div id="result" class="mt-6 rounded-2xl bg-blue-50 p-5 text-lg font-black text-blue-950 ring-1 ring-blue-100" role="status" aria-live="polite">Estimated savings will appear here.</div>
  </section>
  <script is:inline>
    const form = document.getElementById('savings-form');
    const resultBox = document.getElementById('result');
    const readNumber = (id) => Math.max(0, Number(document.getElementById(id)?.value || 0));
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const watts = readNumber('watts');
      const hours = Math.min(24, readNumber('hours'));
      const rate = readNumber('rate');
      const cost = readNumber('cost');
      const monthly = (watts / 1000) * hours * 30 * rate;
      const annual = monthly * 12;
      const payback = monthly > 0 ? cost / monthly : 0;
      const message = monthly > 0
        ? `Estimated monthly savings: $${monthly.toFixed(2)}. Estimated annual savings: $${annual.toFixed(2)}. Payback period: ${payback.toFixed(1)} months.`
        : 'Enter a wattage, saved runtime, and electricity rate above zero to estimate savings.';
      if (resultBox) resultBox.textContent = message;
      window.gtag?.('event','calculator_used',{device_type:'manual', estimated_savings: monthly});
    });
  </script>
</BaseLayout>
