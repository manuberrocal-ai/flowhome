---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Smart Home Recommendation Quiz | FlowHome" description="Get a simple smart home starter recommendation based on your priority and ecosystem." canonicalURL="https://flowhome.dev/quiz/">
  <section class="premium-page-hero">
    <p class="text-sm font-bold uppercase tracking-wide text-blue-700">Starter quiz</p>
    <h1 class="mt-2 text-4xl font-black text-slate-950 md:text-5xl">Find your smart home starter path</h1>
    <p class="mt-3 max-w-2xl text-lg leading-8 text-slate-600">Pick the outcome you care about most. FlowHome will suggest a practical first path instead of throwing a random gadget list at you.</p>
    <div class="mt-8 grid gap-4 md:grid-cols-3" role="list" aria-label="Smart home starter priorities">
      <button type="button" class="quiz premium-card min-h-40 rounded-2xl border border-slate-200 p-6 text-left transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-blue-100" data-result="security" aria-pressed="false"><strong class="text-lg text-slate-950">Security first</strong><span class="mt-2 block text-slate-600">Cameras, doorbells, locks, sensors.</span></button>
      <button type="button" class="quiz premium-card min-h-40 rounded-2xl border border-slate-200 p-6 text-left transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-blue-100" data-result="comfort" aria-pressed="false"><strong class="text-lg text-slate-950">Comfort and routines</strong><span class="mt-2 block text-slate-600">Speakers, displays, lights, plugs.</span></button>
      <button type="button" class="quiz premium-card min-h-40 rounded-2xl border border-slate-200 p-6 text-left transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-blue-100" data-result="cleaning" aria-pressed="false"><strong class="text-lg text-slate-950">Cleaning automation</strong><span class="mt-2 block text-slate-600">Robot vacuums and maintenance gear.</span></button>
    </div>
    <div id="quiz-result" class="mt-6 hidden rounded-2xl bg-blue-50 p-6 font-bold leading-7 text-blue-950 ring-1 ring-blue-100" role="status" aria-live="polite"></div>
  </section>
  <script>
    import { trackEvent } from '../lib/analytics';
    const copy = {
      security: 'Start with a video doorbell or indoor camera, then add a smart lock only after confirming door compatibility, Wi-Fi coverage, privacy settings, and storage costs.',
      comfort: 'Start with a smart speaker/display plus compatible plugs or bulbs. This gives fast daily value through routines, timers, lighting control, and voice access.',
      cleaning: 'Start with a robot vacuum if your floor plan is robot-friendly. Prioritize mapping, dock placement, maintenance costs, and self-empty convenience over marketing suction numbers.'
    };
    const buttons = Array.from(document.querySelectorAll('.quiz'));
    buttons.forEach((button) => button.addEventListener('click', () => {
      const result = button.dataset.result;
      const target = document.getElementById('quiz-result');
      buttons.forEach((item) => {
        const selected = item === button;
        item.setAttribute('aria-pressed', String(selected));
        item.classList.toggle('border-blue-500', selected);
        item.classList.toggle('bg-blue-50', selected);
      });
      if (target) {
        target.classList.remove('hidden');
        target.textContent = copy[result];
      }
      trackEvent('quiz_complete', { result, questions_answered: 1, page_type: 'quiz' });
    }));
  </script>
</BaseLayout>
