---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="FlowHome Account | Save Smart Home Shortlists" description="Create a FlowHome account with Google or email to save smart home shortlists, favorite products, and deal notes." canonicalURL="https://flowhome.dev/account/" noindex={true}>
  <section class="account-hero home-parallax-bg relative isolate overflow-hidden rounded-[2rem] bg-slate-950 p-6 text-white shadow-2xl shadow-slate-950/25 md:p-8 lg:p-10">
    <div class="relative z-10 grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="inline-flex rounded-full bg-cyan-300/10 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-cyan-100 ring-1 ring-cyan-200/20">FlowHome account</p>
        <h1 class="mt-5 max-w-3xl text-4xl font-black leading-tight tracking-tight md:text-5xl">Save your smart-home shortlist.</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">Use Google or email to keep quiz results, favorites, product comparisons, and deal notes ready for your next setup session.</p>
        <div class="mt-6 grid gap-3 text-sm sm:grid-cols-3">
          <div class="rounded-2xl bg-white/8 p-3 ring-1 ring-white/10"><strong class="block text-cyan-100">Shortlists</strong><span class="text-slate-300">Save product picks</span></div>
          <div class="rounded-2xl bg-white/8 p-3 ring-1 ring-white/10"><strong class="block text-cyan-100">Deals</strong><span class="text-slate-300">Track buy timing</span></div>
          <div class="rounded-2xl bg-white/8 p-3 ring-1 ring-white/10"><strong class="block text-cyan-100">Notes</strong><span class="text-slate-300">Keep setup context</span></div>
        </div>
      </div>

      <div class="relative rounded-[1.75rem] border border-white/10 bg-white/95 p-5 text-slate-950 shadow-2xl shadow-slate-950/30 md:p-6">
        <div class="account-google-badge absolute right-5 top-5 grid h-11 w-11 place-items-center rounded-2xl bg-white shadow-md ring-1 ring-slate-200" aria-hidden="true">
          <svg class="h-6 w-6" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/><path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06L5.84 9.9C6.71 7.31 9.14 5.38 12 5.38Z"/></svg>
        </div>
        <div class="rounded-2xl bg-slate-50 p-4 pr-16 ring-1 ring-slate-200">
          <h2 class="text-2xl font-black">Sign in or create account</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">This form is ready for a real auth provider. For now it stores a local account preview on this browser only.</p>
        </div>

        <button type="button" class="account-google mt-5 flex min-h-12 w-full items-center justify-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 font-black text-slate-950 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-200 hover:bg-cyan-50">
          <span class="grid h-8 w-8 place-items-center rounded-xl bg-white shadow-sm ring-1 ring-slate-200"><svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/><path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06L5.84 9.9C6.71 7.31 9.14 5.38 12 5.38Z"/></svg></span>
          Continue with Google
        </button>

        <div class="my-5 flex items-center gap-3 text-xs font-bold uppercase tracking-[0.16em] text-slate-400"><span class="h-px flex-1 bg-slate-200"></span>or email<span class="h-px flex-1 bg-slate-200"></span></div>

        <form class="account-form grid gap-3">
          <label class="grid gap-1 text-sm font-bold text-slate-700">Email
            <input class="min-h-12 rounded-2xl border border-slate-200 bg-white px-4 text-base font-semibold text-slate-950 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-100" type="email" name="email" autocomplete="email" required />
          </label>
          <button type="submit" class="flow-wave min-h-12 rounded-2xl bg-slate-950 px-5 py-3 font-black text-white shadow-lg shadow-slate-950/15">Continue with email</button>
          <p class="account-status min-h-5 text-sm font-bold text-cyan-700" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-4 md:grid-cols-3">
    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm"><h2 class="text-xl font-black text-slate-950">Google sign-in</h2><p class="mt-2 text-slate-600">Designed for OAuth once a provider is connected.</p></article>
    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm"><h2 class="text-xl font-black text-slate-950">Email login</h2><p class="mt-2 text-slate-600">Ready for magic-link or passwordless email auth.</p></article>
    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm"><h2 class="text-xl font-black text-slate-950">Saved picks</h2><p class="mt-2 text-slate-600">Future account sync can store quiz results and favorites.</p></article>
  </section>

  <script is:inline>
    (() => {
      const form = document.querySelector('.account-form');
      const status = document.querySelector('.account-status');
      const google = document.querySelector('.account-google');
      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        const email = new FormData(form).get('email');
        if (typeof email === 'string' && email.includes('@')) {
          localStorage.setItem('flowhome-account-email', email);
          if (status) status.textContent = 'Saved locally on this browser. Real email auth needs provider setup.';
        }
      });
      google?.addEventListener('click', () => {
        if (status) status.textContent = 'Google sign-in UI is ready. Connect Supabase, Clerk, or Auth.js to enable real OAuth.';
      });

    })();
  </script>

  <style is:global>
    .account-hero::before {
      content: "";
      position: absolute;
      inset: -30% -10%;
      z-index: 0;
      pointer-events: none;
      background-image:
        radial-gradient(circle at 78% 12%, rgba(34,211,238,0.34), transparent 22%),
        radial-gradient(circle at 12% 88%, rgba(37,99,235,0.42), transparent 30%),
        radial-gradient(circle at 50% 45%, rgba(20,184,166,0.16), transparent 36%),
        linear-gradient(135deg, #020617 0%, #0f1d49 45%, #075985 78%, #020617 100%);
      background-size: 135% 135%;
         }

    .account-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(125,211,252,0.055) 1px, transparent 1px),
        linear-gradient(90deg, rgba(125,211,252,0.045) 1px, transparent 1px);
      background-size: 44px 44px;
      opacity: 0.24;
         }
  </style>
</BaseLayout>
