---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const reviews = (await getCollection('reviews')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const products = await getCollection('products');
---
<BaseLayout title="Smart Home Reviews | FlowHome" description="Read practical FlowHome smart home reviews with setup notes, compatibility context, pros and cons, comparisons, and deal timing." canonicalURL="https://flowhome.dev/reviews/">
  <section class="rounded-3xl bg-white p-8 shadow-sm">
    <p class="text-sm font-bold uppercase tracking-wide text-blue-700">Reviews</p>
    <h1 class="mt-2 text-4xl font-black text-slate-950">Smart home reviews</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-600">Practical reviews focused on setup, compatibility, daily usefulness, alternatives, and buying timing.</p>
  </section>
  <section class="mt-8 grid gap-6 md:grid-cols-2">
    {reviews.map((review) => {
      const product = products.find((item) => item.data.slug === review.data.productSlug);
      return <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700">{review.data.category?.replaceAll('-', ' ')}</p>
        <h2 class="mt-2 text-2xl font-extrabold text-slate-950"><a href={'/review/' + review.id + '/'} class="hover:text-blue-700">{review.data.title}</a></h2>
        <p class="mt-3 text-slate-600">{review.data.description}</p>
        {product && <p class="mt-3 text-sm text-slate-500">Featured product: {product.data.name}</p>}
        <a href={'/review/' + review.id + '/'} class="mt-5 inline-flex font-bold text-blue-700 hover:underline">Read review →</a>
      </article>;
    })}
  </section>
</BaseLayout>
