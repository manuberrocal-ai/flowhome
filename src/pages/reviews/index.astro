---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProductImage, getProductImageAlt, getCategoryLabel } from '../../lib/product-art';

const reviews = (await getCollection('reviews')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const products = await getCollection('products');
---
<BaseLayout title="Smart Home Reviews | FlowHome" description="Read practical FlowHome smart home reviews with setup notes, compatibility context, pros and cons, comparisons, and deal timing." canonicalURL="https://flowhome.dev/reviews/">
  <section class="premium-page-hero">
    <p class="text-sm font-bold uppercase tracking-wide text-blue-700">Reviews</p>
    <h1 class="mt-2 text-4xl font-black text-slate-950 md:text-5xl">Smart home reviews</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">Practical reviews focused on setup, compatibility, daily usefulness, alternatives, and buying timing — built for people who want fewer returns and smarter purchases.</p>
    <div class="mt-6 flex flex-wrap gap-3 text-sm font-bold">
      <span class="rounded-full border border-blue-100 bg-blue-50 px-4 py-2 text-blue-700">{reviews.length} editorial reviews</span>
      <span class="rounded-full border border-emerald-100 bg-emerald-50 px-4 py-2 text-emerald-700">Compatibility-first</span>
      <span class="rounded-full border border-amber-100 bg-amber-50 px-4 py-2 text-amber-700">Affiliate disclosure included</span>
    </div>
  </section>
  <section class="mt-8 grid gap-6 md:grid-cols-2">
    {reviews.map((review) => {
      const product = products.find((item) => item.data.slug === review.data.productSlug);
      const productData = product?.data;
      const imageSource = productData ? getProductImage(productData) : undefined;
      const imageAlt = productData ? getProductImageAlt(productData) : review.data.title;
      return <article class="premium-card group flex h-full flex-col overflow-hidden p-5 transition duration-300 hover:-translate-y-1 hover:shadow-xl">
        {productData && <div class="flex gap-4">
          <div class="grid h-24 w-24 shrink-0 place-items-center rounded-2xl bg-slate-50 p-2">
            <img src={imageSource} alt={imageAlt} class="h-full w-full object-contain" loading="lazy" decoding="async" fetchpriority="low" width="320" height="320" />
          </div>
          <div class="min-w-0">
            <p class="text-xs font-black uppercase tracking-wide text-blue-700">{getCategoryLabel(review.data.category)}</p>
            <h2 class="mt-1 font-heading text-xl font-black leading-tight text-slate-950"><a href={'/review/' + review.id + '/'} class="hover:text-blue-700">{review.data.title}</a></h2>
          </div>
        </div>}
        {!productData && <>
          <p class="text-xs font-black uppercase tracking-wide text-blue-700">{getCategoryLabel(review.data.category)}</p>
          <h2 class="mt-1 font-heading text-xl font-black leading-tight text-slate-950"><a href={'/review/' + review.id + '/'} class="hover:text-blue-700">{review.data.title}</a></h2>
        </>}
        <p class="mt-4 flex-1 leading-7 text-slate-600">{review.data.description}</p>
        {productData && <div class="mt-5 grid grid-cols-3 gap-2 text-center text-xs font-bold text-slate-600">
          <span class="rounded-2xl bg-orange-50 px-3 py-2 text-orange-700">${productData.price}</span>
          <span class="rounded-2xl bg-blue-50 px-3 py-2 text-blue-700">{productData.rating}/5</span>
          <span class="rounded-2xl bg-slate-50 px-3 py-2">{productData.brand}</span>
        </div>}
        <a href={'/review/' + review.id + '/'} class="premium-secondary-action mt-5 inline-flex min-h-11 items-center justify-center rounded-2xl px-4 py-2 text-sm font-black transition hover:-translate-y-0.5">Read review →</a>
      </article>;
    })}
  </section>
</BaseLayout>
