---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  return categories.map((category) => ({ params: { slug: category.data.slug }, props: { category } }));
}

const { category } = Astro.props;
const products = (await getCollection('products'))
  .filter((product) => product.data.category === category.data.slug && product.data.available)
  .sort((a, b) => (b.data.rating * Math.log10(b.data.reviewCount + 1) + b.data.discountPct / 20) - (a.data.rating * Math.log10(a.data.reviewCount + 1) + a.data.discountPct / 20));
---
<BaseLayout title={category.data.name + ' | FlowHome'} description={category.data.description} canonicalURL={'https://flowhome.dev/category/' + category.data.slug + '/'}>
  <section class="premium-page-hero">
    <p class="text-sm font-bold uppercase tracking-wide text-blue-700">Category</p>
    <h1 class="mt-2 text-4xl font-black text-slate-950">{category.data.name}</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-600">{category.data.description}</p>
    <a href="/products/" class="mt-5 inline-flex font-bold text-blue-700 hover:underline">← All products</a>
  </section>
  <section class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {products.map((product) => <ProductCard product={product} />)}
  </section>
</BaseLayout>
