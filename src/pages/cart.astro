---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="FlowHome Amazon List | Review selected products" description="Review, edit, remove, and send selected FlowHome smart home products to Amazon cart." canonicalURL="https://flowhome.dev/cart/" noindex>
  <section class="flow-cart-page mx-auto max-w-5xl">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan-700">FlowHome list</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">Review your Amazon list</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">Adjust quantities before opening Amazon. Final price, availability, shipping, and checkout happen on Amazon.</p>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_22rem]">
      <div class="rounded-[1.6rem] border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
        <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 pb-4">
          <h2 class="text-xl font-black text-slate-950">Selected products</h2>
          <button type="button" class="flow-cart-page-clear rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-700 transition hover:bg-slate-200" data-cart-page-clear>Clear all</button>
        </div>
        <div class="flow-cart-page-empty py-12 text-center" data-cart-page-empty>
          <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-slate-100 text-slate-500">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h8.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          </div>
          <p class="mt-4 text-lg font-black text-slate-950">Your FlowHome list is empty.</p>
          <a href="/products/" class="mt-4 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-black text-white">Browse products</a>
        </div>
        <div class="divide-y divide-slate-100" data-cart-page-items></div>
      </div>

      <aside class="h-fit rounded-[1.6rem] border border-orange-100 bg-white p-5 shadow-xl shadow-slate-200/70">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-orange-600">Amazon transfer</p>
        <div class="mt-4 rounded-2xl bg-slate-50 p-4">
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm font-bold text-slate-500">Items</span>
            <strong class="text-xl font-black text-slate-950" data-cart-page-count>0</strong>
          </div>
          <div class="mt-2 flex items-center justify-between gap-3">
            <span class="text-sm font-bold text-slate-500">Estimated subtotal</span>
            <strong class="text-xl font-black text-slate-950" data-cart-page-total>$0.00</strong>
          </div>
        </div>
        <button type="button" class="premium-action flow-wave mt-5 inline-flex min-h-14 w-full items-center justify-center rounded-2xl px-5 py-4 text-center text-base font-black text-white" data-cart-page-buy data-fh-amazon-link data-fh-amazon-link>Open Amazon cart</button>
        <p class="mt-3 text-center text-xs font-semibold leading-5 text-slate-500">Amazon may change price or availability. FlowHome does not process checkout.</p>
      </aside>
    </div>
  </section>

  <script is:inline>
    (() => {
      const storageKey = 'flowhome-amazon-list';
      const associateTag = 'flowhome-20';
      const list = document.querySelector('[data-cart-page-items]');
      const empty = document.querySelector('[data-cart-page-empty]');
      const count = document.querySelector('[data-cart-page-count]');
      const total = document.querySelector('[data-cart-page-total]');
      const buy = document.querySelector('[data-cart-page-buy data-fh-amazon-link data-fh-amazon-link]');
      const clear = document.querySelector('[data-cart-page-clear]');

      const readItems = () => {
        try {
          const parsed = JSON.parse(localStorage.getItem(storageKey) || '[]');
          return Array.isArray(parsed) ? parsed.filter((item) => item && item.asin) : [];
        } catch {
          return [];
        }
      };
      const writeItems = (items) => localStorage.setItem(storageKey, JSON.stringify(items));
      const money = (value) => `$${Number(value || 0).toFixed(2)}`;
      const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
      const buildAmazonCartUrl = (items) => {
        const params = new URLSearchParams({ AssociateTag: associateTag });
        items.forEach((item, index) => {
          params.set(`ASIN.${index + 1}`, item.asin);
          params.set(`Quantity.${index + 1}`, String(Math.max(1, Number(item.quantity || 1))));
        });
        return `https://www.amazon.com/gp/aws/cart/add.html?${params.toString()}`;
      };
      const render = () => {
        const items = readItems();
        const totalQty = items.reduce((sum, item) => sum + Math.max(1, Number(item.quantity || 1)), 0);
        const subtotal = items.reduce((sum, item) => sum + Number(item.price || 0) * Math.max(1, Number(item.quantity || 1)), 0);
        if (count) count.textContent = String(totalQty);
        if (total) total.textContent = money(subtotal);
        if (empty) empty.hidden = items.length > 0;
        if (!list) return;
        list.innerHTML = items.map((item) => {
          const qty = Math.max(1, Number(item.quantity || 1));
          return `<article class="flow-cart-page-item" data-asin="${escapeHtml(item.asin)}">
            <a ${'href'}="${escapeHtml(item.url || `/product/${item.slug}/`)}" class="flow-cart-page-item__image"><img ${'src'}="${escapeHtml(item.image)}" alt="${escapeHtml(item.name)}" loading="lazy" decoding="async"></a>
            <div class="min-w-0">
              <a ${'href'}="${escapeHtml(item.url || `/product/${item.slug}/`)}" class="flow-cart-page-item__name">${escapeHtml(item.name)}</a>
              <p class="mt-1 text-sm font-bold text-slate-500">${money(item.price)} each</p>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <button type="button" class="flow-cart-page-qty" data-cart-page-decrease aria-label="Decrease quantity">&minus;</button>
                <span class="flow-cart-page-qty-value">${qty}</span>
                <button type="button" class="flow-cart-page-qty" data-cart-page-increase aria-label="Increase quantity">+</button>
                <button type="button" class="flow-cart-page-remove" data-cart-page-remove>Remove</button>
              </div>
            </div>
            <strong class="flow-cart-page-item__line">${money(Number(item.price || 0) * qty)}</strong>
          </article>`;
        }).join('');
      };
      const mutate = (asin, updater) => {
        const items = readItems();
        const next = updater(items, items.find((item) => item.asin === asin));
        writeItems(next.filter((item) => item && item.asin && Number(item.quantity || 0) > 0));
        render();
      };
      list?.addEventListener('click', (event) => {
        const target = event.target.closest('button');
        if (!target) return;
        const row = target.closest('[data-asin]');
        const asin = row?.dataset.asin;
        if (!asin) return;
        if (target.matches('[data-cart-page-increase]')) mutate(asin, (items, item) => { if (item) item.quantity = Math.max(1, Number(item.quantity || 1)) + 1; return items; });
        if (target.matches('[data-cart-page-decrease]')) mutate(asin, (items, item) => { if (item) item.quantity = Math.max(1, Number(item.quantity || 1)) - 1; return items; });
        if (target.matches('[data-cart-page-remove]')) mutate(asin, (items) => items.filter((item) => item.asin !== asin));
      });
      clear?.addEventListener('click', () => { localStorage.removeItem(storageKey); render(); });
      buy?.addEventListener('click', () => {
        const items = readItems();
        if (!items.length) return;
        window.open(buildAmazonCartUrl(items), '_blank', 'noopener');
      });
      render();
    })();
  </script>
</BaseLayout>
