---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="FlowHome Amazon List | Review selected products" description="Review, edit, remove, and send selected FlowHome smart home products to Amazon cart." canonicalURL="https://flowhome.dev/cart/" noindex>
  <section class="flow-cart-page mx-auto max-w-5xl">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan-700">FlowHome list</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">Review your Amazon list</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">Adjust quantities before opening Amazon. Final price, availability, shipping, and checkout happen on Amazon.</p>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_22rem]">
      <div class="rounded-[1.6rem] border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
        <div class="mb-4 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-amber-950" data-cart-page-recovery role="alert" hidden>
          <p class="font-black">Your saved list could not be read.</p>
          <p class="mt-1 text-sm font-semibold">It has not been changed. Reset it only if you want to replace the saved data with an empty list.</p>
          <button type="button" class="mt-3 min-h-11 rounded-xl border border-amber-700 bg-white px-4 py-2 text-sm font-black text-amber-950" data-cart-page-reset-saved-list>Reset saved list</button>
        </div>
        <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 pb-4">
          <h2 class="text-xl font-black text-slate-950">Selected products</h2>
          <button type="button" class="flow-cart-page-clear min-h-11 rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-700 transition hover:bg-slate-200" data-cart-page-clear>Clear all</button>
        </div>
        <div class="flow-cart-page-empty py-12 text-center" data-cart-page-empty>
          <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-slate-100 text-slate-500">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h8.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          </div>
          <p class="mt-4 text-lg font-black text-slate-950">Your FlowHome list is empty.</p>
          <a href="/products/" class="mt-4 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-black text-white">Browse products</a>
        </div>
        <div class="divide-y divide-slate-100" data-cart-page-items></div>
      </div>

      <aside class="h-fit rounded-[1.6rem] border border-orange-100 bg-white p-5 shadow-xl shadow-slate-200/70">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-orange-600">Amazon transfer</p>
        <div class="mt-4 rounded-2xl bg-slate-50 p-4">
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm font-bold text-slate-500">Items</span>
            <strong class="text-xl font-black text-slate-950" data-cart-page-count>0</strong>
          </div>
          <div class="mt-2 flex items-center justify-between gap-3">
            <span class="text-sm font-bold text-slate-500">Estimated subtotal</span>
            <strong class="text-xl font-black text-slate-950" data-cart-page-total>$0.00</strong>
          </div>
        </div>
        <a class="premium-action flow-wave mt-5 inline-flex min-h-14 w-full items-center justify-center rounded-2xl px-5 py-4 text-center text-base font-black text-white" data-cart-page-buy data-fh-amazon-link target="_blank" rel="nofollow sponsored noopener" aria-disabled="true" tabindex="-1">Open Amazon cart</a>
        <p class="mt-3 text-center text-xs font-semibold leading-5 text-slate-500">Amazon may change price or availability. FlowHome does not process checkout.</p>
        <p class="mt-2 text-center text-xs font-semibold leading-5 text-slate-600" data-cart-page-feedback aria-live="polite"></p>
      </aside>
    </div>
  </section>

  <script>
    import { setupCartPage } from '../lib/cart-client.js';
    setupCartPage();
  </script>
</BaseLayout>
