---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found | FlowHome" description="The page could not be found." noindex>
  <section class="rounded-3xl bg-white p-10 text-center shadow-sm">
    <h1 class="text-5xl font-black text-slate-950">404</h1>
    <p class="mt-4 text-slate-600">That smart home path does not exist yet.</p>
    <a href="/" class="premium-action flow-wave mt-6 inline-flex rounded-xl px-5 py-3 font-black text-white">Back home</a>
  </section>
</BaseLayout>
