---
import BaseLayout from './BaseLayout.astro';
import CompareTable from '../components/CompareTable.astro';
interface Props { products: any[]; title?: string; description?: string; }
const { products, title = 'Smart Home Product Comparison', description = 'Compare smart home products side by side by price, features, compatibility, ratings, and affiliate deal availability.' } = Astro.props;
---
<BaseLayout title={`${title} | FlowHome`} description={description} canonicalURL={Astro.url.href}>
  <section class="space-y-6">
    <div class="rounded-3xl bg-gradient-to-br from-blue-950 via-blue-800 to-cyan-700 p-8 text-white">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-100">FlowHome Compare</p>
      <h1 class="mt-3 text-4xl font-extrabold md:text-5xl">{title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-blue-50">{description}</p>
    </div>
    <CompareTable products={products} />
    <slot />
  </section>
</BaseLayout>
