---
import BaseLayout from './BaseLayout.astro';
import CompareTable from '../components/CompareTable.astro';
interface Props { products: any[]; title: string; description: string; angle: string; guidance: string; updatedThrough?: string; relatedComparisons: any[]; }
const { products, title, description, angle, guidance, updatedThrough, relatedComparisons } = Astro.props;
---
<BaseLayout title={`${title} | FlowHome`} description={description} canonicalURL={`https://flowhome.dev${Astro.url.pathname}`}>
  <section class="space-y-6">
    <div class="rounded-3xl bg-gradient-to-br from-blue-950 via-blue-800 to-cyan-700 p-8 text-white">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-100">FlowHome Compare</p>
      <h1 class="mt-3 text-4xl font-extrabold md:text-5xl">{title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-blue-50">{description}</p>
    </div>
    <section class="rounded-3xl border border-blue-100 bg-blue-50/70 p-6" aria-labelledby="comparison-angle">
      <h2 id="comparison-angle" class="text-2xl font-black text-slate-950">What this comparison helps you decide</h2>
      <p class="mt-3 text-lg leading-8 text-slate-700">{angle}</p>
      <p class="mt-3 text-sm font-semibold text-slate-600">Prices, ratings, and review counts are snapshots from FlowHome product data{updatedThrough ? ` updated through ${updatedThrough}` : ''}; listings can change.</p>
    </section>
    <CompareTable products={products} />
    <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]" aria-labelledby="quick-decision">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 id="quick-decision" class="text-2xl font-black text-slate-950">Quick decision framework</h2>
        <ol class="mt-4 list-decimal space-y-3 pl-5 leading-7 text-slate-700">
          <li>Filter by the compatibility and feature fields that your home actually needs.</li>
          <li>Compare the price snapshot with rating and review count as context.</li>
          <li>Open the product profile and current Amazon listing before purchasing.</li>
        </ol>
        <p class="mt-5 rounded-2xl bg-amber-50 p-4 text-sm font-semibold leading-6 text-amber-900">Decision guidance: {guidance}</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
        {products.map((product) => (
          <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-black uppercase tracking-wide text-blue-700">{product.category.replaceAll('-', ' ')}</p>
            <h2 class="mt-2 text-xl font-black text-slate-950"><a class="hover:text-blue-700 hover:underline" href={`/product/${product.slug}/`}>{product.name}</a></h2>
            <ul class="mt-3 space-y-1 text-sm leading-6 text-slate-600">
              <li><strong>Price:</strong> ${product.price}</li>
              <li><strong>Rating:</strong> {product.rating} / 5 from {product.reviewCount?.toLocaleString()} reviews</li>
              <li><strong>Compatibility:</strong> {[product.matter && 'Matter', product.alexaCompatible && 'Alexa', product.googleHomeCompatible && 'Google Home', product.appleHomeKit && 'Apple HomeKit'].filter(Boolean).join(', ') || 'Check profile'}</li>
            </ul>
            <a class="mt-3 inline-flex min-h-11 items-center font-bold text-blue-700 hover:underline" href={`/category/${product.category}/`}>Browse {product.category.replaceAll('-', ' ')} category</a>
          </article>
        ))}
      </div>
    </section>
    <nav class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm" aria-labelledby="related-comparisons">
      <h2 id="related-comparisons" class="text-2xl font-black text-slate-950">Related comparisons</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        {relatedComparisons.map((comparison) => <a class="inline-flex min-h-11 items-center rounded-full bg-slate-100 px-4 py-2 font-bold text-blue-700 hover:bg-blue-50 hover:underline" href={`/compare/${comparison.slugs.join('-vs-')}/`}>{comparison.title}</a>)}
      </div>
    </nav>
  </section>
</BaseLayout>
