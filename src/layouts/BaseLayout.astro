---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GoogleTranslate from '../components/GoogleTranslate.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';
import AuthGuardModal from '../components/AuthGuardModal.astro';
import { generateOrganizationSchema, generateWebSiteSchema } from '../lib/seo';
import { serializeJsonLd } from '../lib/json-ld.js';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title = 'FlowHome - Smart Home Reviews, Comparisons & Deals',
  description = 'Expert smart home product reviews, side-by-side comparisons, and the best deals on robot vacuums, security cameras, smart speakers, and more.',
  image = '/images/og-default.svg',
  type = 'website',
  canonicalURL = Astro.url.href,
  noindex = false,
} = Astro.props;

const absoluteImage = image.startsWith('http') ? image : new URL(image, Astro.site || Astro.url.origin).href;
const orgSchema = generateOrganizationSchema();
const websiteSchema = generateWebSiteSchema();
const GA4_ID = import.meta.env.PUBLIC_GA4_ID || '';
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || 'GTM-KX37WSZQ';
const CLARITY_ID = import.meta.env.PUBLIC_CLARITY_ID || 'xdyay13jq0';
const isCartPage = Astro.url.pathname === '/cart/' || Astro.url.pathname === '/cart';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content="Astro v7" />
    <meta name="author" content="FlowHome Team" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/images/flowhome-favicon.png" />
    <link rel="apple-touch-icon" href="/images/flowhome-icon-192.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="search" type="application/opensearchdescription+xml" title="FlowHome" href="/opensearch.xml" />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:site_name" content="FlowHome" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <script type="application/ld+json" set:html={serializeJsonLd(orgSchema)} />
    <script type="application/ld+json" set:html={serializeJsonLd(websiteSchema)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    {GA4_ID && <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>}
    {GA4_ID && <script is:inline define:vars={{ GA4_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA4_ID, { attribution_model: 'paid_and_organic_last_click' });
    </script>}
    {GTM_ID && <script is:inline define:vars={{ GTM_ID }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',GTM_ID);
    </script>}
    {CLARITY_ID && <script is:inline define:vars={{ CLARITY_ID }}>
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script",CLARITY_ID);
    </script>}
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-800">
    {GTM_ID && <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>}
    <Header />
    <div class="border-b border-amber-100 bg-amber-50/75">
      <div class="mx-auto max-w-7xl px-4 py-2 text-center text-[11px] font-semibold leading-5 text-amber-900 sm:px-6 lg:px-8">
        FlowHome may earn from qualifying Amazon purchases. Recommendations prioritize usefulness, compatibility, owner feedback, and buying context.
      </div>
    </div>
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />
    <div class="floating-language-switcher" aria-label="Language switcher">
      <GoogleTranslate />
    </div>
    <ExitIntentPopup />
    {!isCartPage && (
      <div class="flow-cart-dock" data-flow-cart-dock hidden aria-live="polite">
        <div class="flow-cart-dock__summary"><span data-flow-cart-count>0</span> selected for Amazon. Prices and availability can change on Amazon.</div>
        <div class="flow-cart-dock__actions">
          <a href="/cart/" class="flow-cart-dock__review">Review list</a>
          <button type="button" class="flow-cart-dock__clear" data-flow-cart-clear>Clear</button>
        </div>
      </div>
    )}

    <script is:inline>
      (() => {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const setupFlowWave = () => {
          const buttons = Array.from(document.querySelectorAll('.flow-wave'));
          if (!buttons.length) return;

          const layer = document.createElement('div');
          layer.className = 'flow-wave-viewport-layer';
          layer.setAttribute('aria-hidden', 'true');
          document.body.appendChild(layer);

          const clips = new Map();
          let syncQueued = false;

          const ensureClip = (button) => {
            let clip = clips.get(button);
            if (clip) return clip;
            clip = document.createElement('div');
            clip.className = 'flow-wave-clip';
            const sample = document.createElement('div');
            sample.className = 'flow-wave-sample';
            const ribbon = document.createElement('div');
            ribbon.className = 'flow-wave-ribbon';
            sample.appendChild(ribbon);
            clip.appendChild(sample);
            layer.appendChild(clip);
            clips.set(button, clip);
            return clip;
          };

          const syncClips = () => {
            buttons.forEach((button) => {
              const rect = button.getBoundingClientRect();
              const clip = ensureClip(button);
              const isVisible = rect.width > 0 && rect.height > 0 && rect.bottom >= 0 && rect.top <= window.innerHeight;
              if (!isVisible) {
                clip.style.display = 'none';
                return;
              }
              const styles = window.getComputedStyle(button);
              clip.style.display = 'block';
              clip.style.left = `${rect.left}px`;
              clip.style.top = `${rect.top}px`;
              clip.style.width = `${rect.width}px`;
              clip.style.height = `${rect.height}px`;
              clip.style.borderRadius = styles.borderRadius;
              clip.style.setProperty('--flow-clip-left', `${rect.left}px`);
              clip.style.setProperty('--flow-clip-top', `${rect.top}px`);
            });
          };

          const queueSync = () => {
            if (syncQueued) return;
            syncQueued = true;
            window.requestAnimationFrame(() => {
              syncQueued = false;
              syncClips();
            });
          };

          syncClips();
          window.addEventListener('scroll', queueSync, { passive: true });
          window.addEventListener('resize', queueSync);
        };

        const setupProductZoom = () => {
          document.querySelectorAll('.product-card-media').forEach((media) => {
            const image = media.querySelector('.product-card-image');
            if (!image) return;
            const card = media.closest('.product-card');
            media.addEventListener('pointerenter', () => card?.classList.add('is-image-zooming'));
            media.addEventListener('pointermove', (event) => {
              const rect = media.getBoundingClientRect();
              const x = Math.min(Math.max(((event.clientX - rect.left) / rect.width) * 100, 0), 100);
              const y = Math.min(Math.max(((event.clientY - rect.top) / rect.height) * 100, 0), 100);
              image.style.setProperty('--product-zoom-x', `${x}%`);
              image.style.setProperty('--product-zoom-y', `${y}%`);
            });
            media.addEventListener('pointerleave', () => {
              card?.classList.remove('is-image-zooming');
              image.style.setProperty('--product-zoom-x', '50%');
              image.style.setProperty('--product-zoom-y', '50%');
            });
          });
        };

        if (!reduceMotion) setupFlowWave();
        if (!reduceMotion) setupProductZoom();
      })();
    </script>
    <script>
      import { setupCartDock } from '../lib/cart-client.js';
      setupCartDock();
    </script>
    <AuthGuardModal />
</body>
</html>
