---
import BaseLayout from './BaseLayout.astro';

interface Props {
  review: any;
  product?: any;
}

const { review, product } = Astro.props;
---

<BaseLayout
  title={`${review.title} | FlowHome`}
  description={review.description || review.title}
  type="article"
  canonicalURL={`https://flowhome.dev/review/${review.slug}`}
  image={product?.image}
>
  <article class="prose prose-lg max-w-none prose-headings:font-heading prose-a:text-blue-600">
    <h1>{review.title}</h1>
    <div class="text-slate-500 text-sm mb-6">
      Published: {review.pubDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </div>
    <div class="affiliate-disclosure">
      <strong>Affiliate Disclosure:</strong> As an Amazon Associate, we earn from qualifying purchases. This review may contain affiliate links.
    </div>
    <slot />
  </article>
</BaseLayout>
