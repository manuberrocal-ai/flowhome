---
interface Props { products: any[]; }
const { products } = Astro.props;
const rows = [
  ['Price', (p:any) => `$${p.price}`],
  ['Rating', (p:any) => `${p.rating} / 5`],
  ['Reviews', (p:any) => `${p.reviewCount?.toLocaleString?.() ?? p.reviewCount}`],
  ['Matter', (p:any) => p.matter ? 'Yes' : 'No'],
  ['Alexa', (p:any) => p.alexaCompatible ? 'Yes' : 'No'],
  ['Google Home', (p:any) => p.googleHomeCompatible ? 'Yes' : 'No'],
  ['Apple HomeKit', (p:any) => p.appleHomeKit ? 'Yes' : 'No'],
  ['Energy monitoring', (p:any) => p.energyMonitoring ? 'Yes' : 'No'],
];
---
<div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
  <table class="compare-table min-w-full text-sm">
    <caption class="sr-only">Side-by-side product data comparison</caption>
    <thead>
      <tr>
        <th scope="col">Feature</th>
        {products.map((product) => <th scope="col" class="min-w-48">{product.name}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map(([label, getter]) => <tr><th scope="row" class="font-bold text-slate-700">{label}</th>{products.map((product) => <td>{getter(product)}</td>)}</tr>)}
      <tr>
        <th scope="row" class="font-bold text-slate-700">Listing link</th>
        {products.map((product) => <td><a href={product.affiliateUrl} target="_blank" rel="nofollow sponsored noopener" class="font-bold text-blue-700 hover:underline" data-fh-amazon-cta data-product-slug={product.slug} data-category={product.category} data-discount={product.discountPct} data-cta-position="compare_table">Check on Amazon</a></td>)}
      </tr>
    </tbody>
  </table>
</div>
