---
import { getProductImage, getProductImageAlt } from '../lib/product-art';

interface Props { deal: any; product?: any; }
const { deal, product } = Astro.props;
const data = deal.data ?? deal;
const productData = product?.data ?? product;
const imageSource = getProductImage(productData ?? { image: data.image, category: undefined, name: data.title });
const imageAlt = getProductImageAlt(productData ?? { image: data.image, category: undefined, name: data.title });
const productSlug = productData?.slug ?? data.productSlug ?? '';
const category = productData?.category ?? data.category ?? '';
---
<article class="premium-card rounded-2xl border border-orange-100 bg-white p-5 shadow-sm">
  <div class="flex items-start gap-4">
    <img src={imageSource} alt={imageAlt} class="h-24 w-24 rounded-xl bg-slate-100 object-contain" loading="lazy" decoding="async" fetchpriority="low" width="640" height="480" />
    <div class="min-w-0 flex-1">
      <div class="deal-badge inline-flex">Save {data.discountPct}%</div>
      <h2 class="mt-2 font-heading text-xl font-extrabold text-slate-950">{data.title}</h2>
      <p class="mt-1 text-sm text-slate-500">Deal ends {new Date(data.endDate).toLocaleDateString('en-US')}</p>
      <div class="mt-3 flex items-center gap-3">
        <span class="text-2xl font-black text-orange-600">${data.dealPrice}</span>
        <span class="text-slate-400 line-through">${data.originalPrice}</span>
      </div>
      <a href={data.affiliateUrl} target="_blank" rel="nofollow sponsored noopener" class="premium-action flow-wave mt-4 inline-flex min-h-11 items-center rounded-xl px-4 py-2 text-sm font-black text-white" data-fh-amazon-cta data-product-slug={productSlug} data-category={category} data-discount={data.discountPct} data-cta-position="deal_card"><span class="amazon-cta-label">Check on <span class="amazon-cta-word">Amazon<svg class="amazon-cta-smile" viewBox="0 0 64 18" aria-hidden="true"><path d="M9 5c12 9 31 10 46 1" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/><path d="M50 3l7 2-4 6" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg></span></span></a>
    </div>
  </div>
</article>
