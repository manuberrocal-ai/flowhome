---
const nav = [
  { href: '/products/', label: 'Products' },
  { href: '/search/', label: 'Search' },
  { href: '/deals/', label: 'Deals' },
  { href: '/calculator/', label: 'Savings Calculator' },
  { href: '/quiz/', label: 'Smart Home Quiz' },
  { href: '/best/best-smart-home-starter-kit/', label: 'Best Picks' },
  { href: '/about/', label: 'About' },
];
---
<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3" aria-label="FlowHome home">
      <span class="grid h-10 w-10 place-items-center rounded-2xl bg-blue-600 text-xl font-black text-white">F</span>
      <span>
        <span class="block font-heading text-xl font-extrabold text-slate-950">FlowHome</span>
        <span class="hidden text-xs font-medium text-slate-500 sm:block">Smarter homes, fewer bad buys</span>
      </span>
    </a>
    <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-700 md:flex" aria-label="Main navigation">
      {nav.map((item) => <a class="hover:text-blue-600" href={item.href}>{item.label}</a>)}
    </nav>
    <a href="/deals/" class="rounded-full bg-orange-500 px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-orange-600">Today's deals</a>
  </div>
</header>
