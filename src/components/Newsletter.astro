---
interface Props { source?: string; }
const { source = 'site' } = Astro.props;
---
<section class="rounded-3xl bg-slate-950 p-8 text-white shadow-xl">
  <div class="grid gap-6 md:grid-cols-[1.2fr_1fr] md:items-center">
    <div>
      <h2 class="text-3xl font-extrabold">Get the weekly smart home deal brief</h2>
      <p class="mt-3 text-slate-300">One concise email with price drops, practical smart home picks, and setup ideas. No spam, no daily noise.</p>
    </div>
    <form class="flex gap-2" action="https://app.convertkit.com/forms/0000000/subscriptions" method="post" data-source={source}>
      <label class="sr-only" for={`email-${source}`}>Email address</label>
      <input id={`email-${source}`} name="email_address" type="email" required placeholder="you@example.com" class="min-w-0 flex-1 rounded-xl border-0 px-4 py-3 text-slate-900" />
      <button class="rounded-xl bg-orange-500 px-5 py-3 font-bold text-white hover:bg-orange-600">Join</button>
    </form>
  </div>
</section>
