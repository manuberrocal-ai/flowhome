<div class="fh-auth-modal" data-fh-auth-modal hidden>
  <div class="fh-auth-modal__backdrop" data-fh-auth-close></div>
  <div class="fh-auth-modal__card">
    <button type="button" class="fh-auth-modal__close" data-fh-auth-close aria-label="Close">&times;</button>
    <div class="fh-auth-modal__google-badge">
      <svg class="h-7 w-7" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/><path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06L5.84 9.9C6.71 7.31 9.14 5.38 12 5.38Z"/></svg>
    </div>
    <h2 class="fh-auth-modal__title">Sign in to continue to Amazon</h2>
    <p class="fh-auth-modal__subtitle">Log in with Google to check prices, add to your list, and sync your picks across devices.</p>
    <div class="fh-auth-modal__google-btn" data-fh-auth-google aria-label="Continue with Google"></div>
    <p class="fh-auth-modal__status" data-fh-auth-status aria-live="polite"></p>
  </div>
</div>

<script>
  import { getSupabaseClient } from '../lib/supabase-client';
  import { registerGoogleCredentialHandler } from '../lib/google-identity';

  (async () => {
    const modal = document.querySelector('[data-fh-auth-modal]');
    if (!modal) return;
    const closeBtns = modal.querySelectorAll('[data-fh-auth-close]');
    const googleButton = modal.querySelector('[data-fh-auth-google]');
    const statusEl = modal.querySelector('[data-fh-auth-status]');
    let pendingUrl = null;
    let pendingLink = null;
    let googleSignIn = null;
    let completingSignIn = false;
    let authCheckInFlight = false;
    const supabase = getSupabaseClient();

    if (!supabase) {
      if (statusEl) statusEl.textContent = 'Auth not available.';
      return;
    }

    const isLoggedIn = async () => {
      try {
        const { data, error } = await supabase.auth.getSession();
        if (error) {
          if (statusEl) statusEl.textContent = 'We could not verify your sign-in status. Please try again.';
          return null;
        }
        return Boolean(data.session?.user);
      } catch {
        if (statusEl) statusEl.textContent = 'We could not verify your sign-in status. Please try again.';
        return null;
      }
    };

    const openModal = (url, link) => {
      pendingUrl = url;
      pendingLink = link || null;
      completingSignIn = false;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      googleSignIn?.activate();
    };
    const closeModal = () => {
      modal.hidden = true;
      pendingUrl = null;
      pendingLink = null;
      document.body.style.overflow = '';
      if (statusEl) statusEl.textContent = '';
      googleSignIn?.deactivate();
    };

    const getSafeDestination = (destination) => {
      try {
        const url = new URL(destination, window.location.origin);
        const isLocalHttp = url.protocol === 'http:' && ['localhost', '127.0.0.1', '[::1]'].includes(url.hostname);
        return url.protocol === 'https:' || isLocalHttp ? url : null;
      } catch {
        return null;
      }
    };

    const continueToDestination = (destination, link) => {
      const url = getSafeDestination(destination);
      if (!url) {
        if (statusEl) statusEl.textContent = 'That destination is not available.';
        return;
      }

      const target = link instanceof HTMLAnchorElement ? link.target : '';
      if (target && !['_self', '_top', '_parent'].includes(target)) {
        const opened = window.open(url.href, target, 'noopener');
        if (opened) opened.opener = null;
        else window.location.assign(url.href);
        return;
      }

      window.location.assign(url.href);
    };

    const continueToPendingUrl = () => {
      if (completingSignIn) return;
      completingSignIn = true;
      const destination = pendingUrl;
      const link = pendingLink;
      closeModal();
      if (destination) continueToDestination(destination, link);
    };

    closeBtns.forEach((btn) => btn.addEventListener('click', closeModal));

    try {
      googleSignIn = await registerGoogleCredentialHandler('auth-modal', async (response) => {
        if (!response.credential) {
          if (statusEl) statusEl.textContent = 'Google did not return a sign-in credential.';
          return;
        }

        if (statusEl) statusEl.textContent = 'Signing you in...';
        try {
          const { error } = await supabase.auth.signInWithIdToken({ provider: 'google', token: response.credential });
          if (error && statusEl) statusEl.textContent = error.message;
        } catch {
          if (statusEl) statusEl.textContent = 'Sign-in failed. Please try again.';
        }
      });
      if (googleButton) googleSignIn.renderButton(googleButton);
    } catch (error) {
      if (statusEl) statusEl.textContent = error instanceof Error ? error.message : 'Google sign-in is unavailable.';
    }

    window.fhRequireAuth = async (url, event, link) => {
      event?.preventDefault();
      if (authCheckInFlight) return false;
      authCheckInFlight = true;
      try {
        const signedIn = await isLoggedIn();
        if (signedIn === null) return false;
        if (signedIn) {
          continueToDestination(url, link || event?.currentTarget);
          return true;
        }
        openModal(url, link || event?.currentTarget);
        return false;
      } finally {
        authCheckInFlight = false;
      }
    };

    document.addEventListener('click', (event) => {
      const link = event.target.closest('[data-fh-amazon-link]');
      if (!link || event.defaultPrevented) return;
      const url = link.href || link.dataset.href;
      if (!url) return;
      void window.fhRequireAuth(url, event, link);
    });

    supabase.auth.onAuthStateChange((event) => {
      if (event === 'SIGNED_IN' && !modal.hidden) continueToPendingUrl();
    });
  })();
</script>

<style is:global>
  .fh-auth-modal { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .fh-auth-modal[hidden] { display: none; }
  .fh-auth-modal__backdrop { position: absolute; inset: 0; background: rgba(15,23,42,0.65); backdrop-filter: blur(4px); }
  .fh-auth-modal__card { position: relative; z-index: 1; width: 100%; max-width: 26rem; border-radius: 1.75rem; background: white; padding: 2rem; box-shadow: 0 25px 60px rgba(0,0,0,0.25); }
  .fh-auth-modal__close { position: absolute; right: 1rem; top: 0.75rem; font-size: 1.75rem; line-height: 1; color: #94a3b8; background: none; border: none; cursor: pointer; padding: 0.25rem 0.5rem; transition: color 0.2s; }
  .fh-auth-modal__close:hover { color: #0f172a; }
  .fh-auth-modal__google-badge { display: flex; justify-content: center; margin-bottom: 1.25rem; }
  .fh-auth-modal__title { font-size: 1.35rem; font-weight: 900; text-align: center; color: #0f172a; line-height: 1.3; }
  .fh-auth-modal__subtitle { margin-top: 0.5rem; font-size: 0.875rem; line-height: 1.5; color: #64748b; text-align: center; }
  .fh-auth-modal__google-btn { display: flex; min-height: 3rem; margin-top: 1.5rem; justify-content: center; }
  .fh-auth-modal__status { margin-top: 1rem; font-size: 0.875rem; font-weight: 700; color: #0e7490; text-align: center; min-height: 1.25rem; }
</style>
